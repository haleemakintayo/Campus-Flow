// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: buses
// Document ID: {busId}
// Fields:
//   - id: string (required)
//   - routeId: string (required)
//   - name: string (required)
//   - latitude: number (required)
//   - longitude: number (required)
//   - capacity: number (required)
//   - currentOccupancy: number (required)
//   - status: string (required, enum: ['active', 'maintenance', 'idle'])
//   - lastUpdated: string (required, ISO 8601)
//   - heading: number (optional)
//
// Collection: routes
// Document ID: {routeId}
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - color: string (required)
//   - stops: array of Stop objects (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "haleemakintayo@gmail.com");
    }

    function isValidBus(data) {
      return data.keys().hasAll(['id', 'routeId', 'name', 'latitude', 'longitude', 'capacity', 'currentOccupancy', 'status', 'lastUpdated']) &&
             data.id is string &&
             data.routeId is string &&
             data.name is string && data.name.size() < 100 &&
             data.latitude is number &&
             data.longitude is number &&
             data.capacity is number && data.capacity > 0 &&
             data.currentOccupancy is number && data.currentOccupancy >= 0 &&
             data.status in ['active', 'maintenance', 'idle'] &&
             data.lastUpdated is string;
    }

    function isValidRoute(data) {
      return data.keys().hasAll(['id', 'name', 'color', 'stops']) &&
             data.id is string &&
             data.name is string && data.name.size() < 100 &&
             data.color is string && data.color.matches('^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$') &&
             data.stops is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Buses: Publicly readable by authenticated users, writable only by admins
    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidBus(request.resource.data);
      allow delete: if isAdmin();
    }

    // Routes: Publicly readable by authenticated users, writable only by admins
    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidRoute(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users: Private profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
